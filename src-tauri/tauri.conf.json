{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "devtools": true
  },
  "package": {
    "productName": "Messenger",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.messenger.app"
    },
    "security": { "csp": null },
    "windows": [{
      "fullscreen": false,
      "resizable": true,
      "title": "Messenger",
      "width": 1000,
      "height": 700,
      "minWidth": 800,
      "minHeight": 600
    }]
  }
}
